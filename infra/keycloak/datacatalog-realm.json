{
  "realm": "datacatalog",
  "enabled": true,
  "displayName": "Data Catalog",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,

  "accessTokenLifespan": 3600,
  "refreshTokenMaxReuse": 0,

  "clients": [
    {
      "clientId": "catalog-frontend",
      "name": "Data Catalog Frontend",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://catalog.local/*",
        "http://manage.catalog.local/*",
        "http://localhost:3000/*",
        "http://localhost:3001/*"
      ],
      "webOrigins": ["+"],
      "protocol": "openid-connect",
      "defaultClientScopes": ["openid", "profile", "email", "catalog-scopes"]
    },
    {
      "clientId": "identity-service",
      "name": "Identity Service (machine-to-machine)",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "change-me-in-production",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "protocol": "openid-connect"
    },
    {
      "clientId": "catalog-api",
      "name": "Catalog API (resource server)",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "catalog-api-secret",
      "bearerOnly": true,
      "protocol": "openid-connect",
      "defaultClientScopes": ["catalog-scopes"]
    }
  ],

  "clientScopes": [
    {
      "name": "catalog-scopes",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true" },
      "protocolMappers": [
        {
          "name": "tenant_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "tenant_id",
            "claim.name": "tenant_id",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "true"
          }
        },
        {
          "name": "permissions",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "permissions",
            "claim.name": "permissions",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "multivalued": "true"
          }
        },
        {
          "name": "realm_roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "realm_access.roles",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "multivalued": "true"
          }
        }
      ]
    }
  ],

  "roles": {
    "realm": [
      { "name": "administrator",   "description": "Full platform administration — manages users, all data assets, harvest sources, and settings" },
      { "name": "data-governance", "description": "Data Governance officer — governs data quality and compliance across domains" },
      { "name": "data-owner",      "description": "Data Owner — owns and manages data products and datasets within their domain" },
      { "name": "data-steward",    "description": "Data Steward — curates metadata, semantic annotations, and logical models" }
    ]
  },

  "users": [
    {
      "username": "admin@datacatalog.local",
      "email": "admin@datacatalog.local",
      "firstName": "Catalog",
      "lastName": "Admin",
      "enabled": true,
      "credentials": [{ "type": "password", "value": "admin", "temporary": false }],
      "realmRoles": ["administrator"],
      "attributes": {
        "tenant_id":   ["00000000-0000-0000-0000-000000000001"],
        "permissions": ["catalog:read", "catalog:write", "catalog:admin"]
      }
    },
    {
      "username": "governance@datacatalog.local",
      "email": "governance@datacatalog.local",
      "firstName": "Grace",
      "lastName": "Governance",
      "enabled": true,
      "credentials": [{ "type": "password", "value": "password", "temporary": false }],
      "realmRoles": ["data-governance"],
      "attributes": {
        "tenant_id":   ["00000000-0000-0000-0000-000000000001"],
        "permissions": ["catalog:read", "catalog:write"]
      }
    },
    {
      "username": "owner@datacatalog.local",
      "email": "owner@datacatalog.local",
      "firstName": "Owen",
      "lastName": "Owner",
      "enabled": true,
      "credentials": [{ "type": "password", "value": "password", "temporary": false }],
      "realmRoles": ["data-owner"],
      "attributes": {
        "tenant_id":   ["00000000-0000-0000-0000-000000000001"],
        "permissions": ["catalog:read", "catalog:write"]
      }
    },
    {
      "username": "steward@datacatalog.local",
      "email": "steward@datacatalog.local",
      "firstName": "Sam",
      "lastName": "Steward",
      "enabled": true,
      "credentials": [{ "type": "password", "value": "password", "temporary": false }],
      "realmRoles": ["data-steward"],
      "attributes": {
        "tenant_id":   ["00000000-0000-0000-0000-000000000001"],
        "permissions": ["catalog:read", "catalog:write"]
      }
    }
  ],

  "userProfile": {
    "attributes": [
      {
        "name": "username",
        "displayName": "${username}",
        "validations": { "length": { "min": 3, "max": 255 }, "username-prohibited-characters": {}, "up-username-not-idn-homograph": {} },
        "permissions": { "view": ["admin", "user"], "edit": ["admin", "user"] }
      },
      {
        "name": "email",
        "displayName": "${email}",
        "validations": { "email": {}, "length": { "max": 255 } },
        "required": { "roles": ["user"] },
        "permissions": { "view": ["admin", "user"], "edit": ["admin", "user"] }
      },
      {
        "name": "firstName",
        "displayName": "${firstName}",
        "validations": { "length": { "max": 255 }, "person-name-prohibited-characters": {} },
        "permissions": { "view": ["admin", "user"], "edit": ["admin", "user"] }
      },
      {
        "name": "lastName",
        "displayName": "${lastName}",
        "validations": { "length": { "max": 255 }, "person-name-prohibited-characters": {} },
        "permissions": { "view": ["admin", "user"], "edit": ["admin", "user"] }
      },
      {
        "name": "tenant_id",
        "displayName": "Tenant ID",
        "multivalued": false,
        "permissions": { "view": ["admin"], "edit": ["admin"] }
      },
      {
        "name": "permissions",
        "displayName": "Permissions",
        "multivalued": true,
        "permissions": { "view": ["admin"], "edit": ["admin"] }
      }
    ]
  }
}
