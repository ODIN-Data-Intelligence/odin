{
  "settings": {
    "number_of_shards": 3,
    "number_of_replicas": 1,
    "analysis": {
      "analyzer": {
        "english_standard": {
          "type": "custom",
          "tokenizer": "standard",
          "filter": ["lowercase", "english_stop", "english_stemmer"]
        }
      },
      "filter": {
        "english_stop": {
          "type": "stop",
          "stopwords": "_english_"
        },
        "english_stemmer": {
          "type": "stemmer",
          "language": "english"
        }
      }
    }
  },
  "mappings": {
    "properties": {
      "id":                   { "type": "keyword" },
      "tenantId":             { "type": "keyword" },
      "entityType":           { "type": "keyword" },
      "title": {
        "type": "text",
        "analyzer": "english_standard",
        "fields": { "keyword": { "type": "keyword", "ignore_above": 512 } }
      },
      "description":          { "type": "text", "analyzer": "english_standard" },
      "keywords":             { "type": "text", "analyzer": "english_standard",
                                "fields": { "keyword": { "type": "keyword" } } },
      "themes":               { "type": "keyword" },
      "domainId":             { "type": "keyword" },
      "domainName":           { "type": "keyword" },
      "ownerId":              { "type": "keyword" },
      "ownerName":            { "type": "keyword" },
      "lifecycleStatus":      { "type": "keyword" },
      "informationSensitivity": { "type": "keyword" },
      "license":              { "type": "keyword" },
      "language":             { "type": "keyword" },
      "format":               { "type": "keyword" },
      "mediaType":            { "type": "keyword" },
      "accrualPeriodicity":   { "type": "keyword" },
      "sourceUri":            { "type": "keyword" },
      "issued":               { "type": "date" },
      "modified":             { "type": "date" },
      "isDeleted":            { "type": "boolean" },

      "distributionCount":    { "type": "integer" },
      "hasLineage":           { "type": "boolean" },
      "hasLogicalModel":      { "type": "boolean" },
      "datasetId":            { "type": "keyword" },

      "logical_element_names":  { "type": "text", "analyzer": "english_standard" },
      "logical_element_labels": { "type": "keyword" },
      "logical_types":          { "type": "keyword" },
      "vocab_concept_iris":     { "type": "keyword" },
      "vocab_concept_labels":   { "type": "text", "analyzer": "english_standard",
                                  "fields": { "keyword": { "type": "keyword" } } },
      "vocabulary_types":       { "type": "keyword" },
      "fibo_concepts":          { "type": "keyword" },
      "semanticTypes":          { "type": "keyword" },

      "column_names": {
        "type": "text",
        "analyzer": "english_standard",
        "fields": { "keyword": { "type": "keyword" } }
      },
      "column_descriptions":  { "type": "text", "analyzer": "english_standard" },

      "catalogId":            { "type": "keyword" },
      "dataProductId":        { "type": "keyword" },

      "embedding": {
        "type": "knn_vector",
        "dimension": 768,
        "method": {
          "name": "hnsw",
          "space_type": "cosinesimil",
          "engine": "nmslib",
          "parameters": { "ef_construction": 128, "m": 24 }
        }
      }
    }
  }
}
