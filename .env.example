# ── Postgres passwords ────────────────────────────────────────────────────
INVENTORY_DB_PASSWORD=inventory_secret
HARVEST_DB_PASSWORD=harvest_secret
LINEAGE_DB_PASSWORD=lineage_secret
IDENTITY_DB_PASSWORD=identity_secret
AI_DB_PASSWORD=ai_secret

# ── Kafka ─────────────────────────────────────────────────────────────────
KAFKA_CLUSTER_ID=Ol5nhRq2T-W_ymX0iqMKlA

# ── OpenSearch ───────────────────────────────────────────────────────────
OPENSEARCH_INITIAL_ADMIN_PASSWORD=Admin@1234!

# ── MinIO ─────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ── Keycloak ─────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_URL=http://localhost:8180
APP_URL=http://localhost:3000
KEYCLOAK_CLIENT_SECRET=change-me-in-production

# ── Dev auth bypass (set to false or omit in production) ─────────────────
APP_DEV_AUTH_ENABLED=true

# ── Consumer UI service account key ──────────────────────────────────────
# In production, issue a real API key via identity-service and set here.
CONSUMER_API_KEY=dev-consumer

# ── AI providers ─────────────────────────────────────────────────────────
# Ollama must be running externally; point this at your Ollama host
SPRING_AI_OLLAMA_BASE_URL=http://localhost:11434
OPENAI_API_KEY=

# ── AWS (for Glue connector) ─────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# ── Snowflake (for Snowflake connector) ───────────────────────────────────
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=

# ── Teradata (for Teradata connector) ─────────────────────────────────────
TERADATA_HOST=
TERADATA_USER=
TERADATA_PASSWORD=
